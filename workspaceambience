<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ambient Mixer - Final Fix</title>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --bg: #0a0a0a;
            --card: #141414;
            --neon: #00f2ff;
            --text: #ffffff;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 40px;
        }

        .tile {
            width: 140px;
            height: 140px;
            background: var(--card);
            border: 1px solid #222;
            border-radius: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.3s;
        }

        .tile i { margin-bottom: 10px; stroke: #444; }
        .tile span { font-size: 0.7rem; letter-spacing: 1px; opacity: 0.5; }

        .tile.active {
            border-color: var(--neon);
            box-shadow: 0 0 15px rgba(0, 242, 255, 0.3);
            animation: breathe 3s ease-in-out infinite;
        }

        .tile.active i { stroke: var(--neon); }

        @keyframes breathe {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .controls { width: 280px; text-align: center; }
        
        .vol-row {
            display: flex;
            align-items: center;
            gap: 15px;
            background: #1a1a1a;
            padding: 10px 20px;
            border-radius: 50px;
            margin-bottom: 20px;
        }

        input[type="range"] { flex-grow: 1; accent-color: var(--neon); cursor: pointer; }

        button {
            background: none;
            border: 1px solid #333;
            color: #555;
            padding: 10px 20px;
            border-radius: 10px;
            cursor: pointer;
            font-size: 0.7rem;
        }

        button:hover { color: #ff4b2b; border-color: #ff4b2b; }
    </style>
</head>
<body>

    <div class="grid">
        <div class="tile" onclick="toggleSound('rain', this)">
            <i data-lucide="cloud-rain"></i>
            <span>RAIN</span>
        </div>
        <div class="tile" onclick="toggleSound('hum', this)">
            <i data-lucide="zap"></i>
            <span>ALPHA HUM</span>
        </div>
        <div class="tile" onclick="toggleSound('forest', this)">
            <i data-lucide="trees"></i>
            <span>WIND</span>
        </div>
        <div class="tile" onclick="toggleSound('waves', this)">
            <i data-lucide="waves"></i>
            <span>WAVES</span>
        </div>
    </div>

    <div class="controls">
        <div class="vol-row">
            <i data-lucide="volume-2" size="16"></i>
            <input type="range" id="master-vol" min="0" max="1" step="0.1" value="0.5">
        </div>
        <button onclick="stopAll()">STOP ALL</button>
    </div>

    <script>
        lucide.createIcons();

        // Web Audio Context (The magic engine)
        let audioCtx;
        const activeNodes = {};

        function initAudio() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            }
        }

        function createWhiteNoise() {
            const bufferSize = 2 * audioCtx.sampleRate;
            const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
            const output = buffer.getChannelData(0);
            for (let i = 0; i < bufferSize; i++) {
                output[i] = Math.random() * 2 - 1;
            }
            return buffer;
        }

        function toggleSound(type, el) {
            initAudio();
            if (audioCtx.state === 'suspended') audioCtx.resume();

            if (el.classList.contains('active')) {
                activeNodes[type].stop();
                delete activeNodes[type];
                el.classList.remove('active');
                return;
            }

            // Sound Generation Logic
            const source = audioCtx.createBufferSource();
            const filter = audioCtx.createBiquadFilter();
            const gainNode = audioCtx.createGain();

            source.buffer = createWhiteNoise();
            source.loop = true;

            // Sculpt the sound based on type
            if (type === 'rain') {
                filter.type = 'lowpass';
                filter.frequency.value = 400;
            } else if (type === 'waves') {
                filter.type = 'lowpass';
                filter.frequency.value = 200;
                // Wave modulation
                const lfo = audioCtx.createOscillator();
                lfo.frequency.value = 0.2;
                const lfoGain = audioCtx.createGain();
                lfoGain.gain.value = 0.5;
                lfo.connect(lfoGain);
                lfoGain.connect(gainNode.gain);
                lfo.start();
            } else if (type === 'hum') {
                const osc = audioCtx.createOscillator();
                osc.type = 'sine';
                osc.frequency.value = 110; // Low Alpha/Beta frequency
                osc.connect(gainNode);
                osc.start();
                activeNodes[type] = osc;
                osc.connect(audioCtx.destination);
                el.classList.add('active');
                return;
            } else {
                filter.type = 'bandpass';
                filter.frequency.value = 800;
            }

            source.connect(filter);
            filter.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            
            gainNode.gain.value = document.getElementById('master-vol').value;
            source.start();
            
            activeNodes[type] = source;
            el.classList.add('active');
        }

        function stopAll() {
            Object.values(activeNodes).forEach(node => node.stop());
            document.querySelectorAll('.tile').forEach(t => t.classList.remove('active'));
        }
    </script>
</body>
</html>
